# New-API 环境变量配置示例
# 
# 使用方法:
#   1. 复制此文件为 .env
#   2. 修改下面的配置值
#
# ⚠️ 警告: .env 文件包含敏感信息，请勿提交到 Git!

# 服务端口
PORT=3000

# 会话密钥 (必须修改为随机字符串!)
SESSION_SECRET=your_random_session_secret_here

# Clash 代理组名称
CLASH_PROXY_GROUP=GLOBAL

# ============================================
# 以下配置通常不需要修改
# ============================================

# 时区
TZ=Asia/Shanghai

# Redis 连接 (使用 Docker 内部网络)
REDIS_CONN_STRING=redis://redis

# 代理配置
HTTP_PROXY=http://mihomo:7890
HTTPS_PROXY=http://mihomo:7890
CLASH_API_URL=http://mihomo:9090

# 日志
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true